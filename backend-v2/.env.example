# Brain Overflow — Backend v2 Environment Variables
# Copy this file to .env and fill in your values, then run: npm run setup
#
# Key naming follows Supabase's current terminology:
#   Publishable Key = formerly "anon key"  (safe to ship in mobile apps)
#   Secret Key      = formerly "service_role key"  (NEVER expose publicly)

# ─── Supabase Project ──────────────────────────────────────────────────────────
# Project reference ID — find in: Project Settings → General
SUPABASE_PROJECT_REF=your-project-ref-here

# Project URL — find in: Project Settings → API
SUPABASE_URL=https://your-project-ref-here.supabase.co

# Publishable Key (formerly anon key) — Project Settings → API → Publishable
# Give this to the Flutter app.
SUPABASE_PUBLISHABLE_KEY=eyJ...

# Secret Key (formerly service_role key) — Project Settings → API → Secret
# NEVER share this. Used only by setup/seed/verify scripts.
SUPABASE_SECRET_KEY=eyJ...

# ─── AI Provider Keys ──────────────────────────────────────────────────────────
# Injected into Supabase Edge Function secrets by npm run setup.
# The mobile app NEVER sees any of these.

# Fireworks AI (default provider) — https://fireworks.ai
AI_API_KEY=fw_...

# OpenAI (optional — needed only if you add openai models)
# OPENAI_API_KEY=sk-...

# Anthropic (optional — needed only if you add anthropic models)
# ANTHROPIC_API_KEY=sk-ant-...
